# JWT_SECRET: обязателен в production (NODE_ENV=production) — без него процесс не запустится.
# В разработке можно не задавать: сервер сгенерирует временный секрет на старте (см. server/middlewares/tenant.ts).
JWT_SECRET="change_me_to_a_long_random_string"

# NODE_ENV: "development" (по умолчанию) или "production".
NODE_ENV="development"

# PORT: порт HTTP-сервера. По умолчанию 3000.
PORT=3000

# DB_DIR / DB_PATH: расположение файла SQLite базы данных (node:sqlite).
# По умолчанию ./data/crm.db
# DB_DIR="./data"
# DB_PATH="./data/crm.db"
