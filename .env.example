# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Стандартные переменные драйвера pg — читаются автоматически из окружения.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=restaurant_crm

# ── Сервер ───────────────────────────────────────────────────────────────────
# JWT_SECRET: ОБЯЗАТЕЛЕН в production. Минимум 32 символа случайной строки.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change_me_to_a_long_random_string_min_32_chars"

NODE_ENV="development"
PORT=3001

# ── Twilio — WhatsApp и SMS уведомления гостям ───────────────────────────────
# Sandbox для тестов (бесплатно): console.twilio.com → Messaging → Try WhatsApp
# Если не задано — уведомления WhatsApp отключены (ресторан может задать свои ключи в Settings)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Resend — Email уведомления ───────────────────────────────────────────────
# 3000 писем/месяц бесплатно: resend.com → API Keys
# Если не задано — email-уведомления отключены (ресторан может задать свой ключ в Settings)
RESEND_API_KEY=re_xxxxxxxxxx
